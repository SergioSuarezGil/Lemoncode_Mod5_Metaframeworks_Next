{
  "name": "casas-rurales",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 -H localhost",
    "dev:quiet": "next dev -p 3000 -H localhost > /dev/null 2>&1",
    "dev:api": "tsx api-server/src/index.ts",
    "dev:all": "concurrently -n FRONT,API -c cyan,green \"npm run dev\" \"npm run dev:api\"",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write ."
  },
  "dependencies": {
    "@material-tailwind/react": "latest",
    "@tailwindcss/postcss": "^4.2.2",
    "next": "latest",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.7",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.5.0",
    "concurrently": "latest",
    "eslint": "latest",
    "hono": "^4.11.0",
    "immutable": "^5.1.5",
    "postcss": "^8.5.10",
    "prettier": "latest",
    "sass": "latest",
    "source-map-js": "^1.2.1",
    "tailwindcss": "^3.3.5",
    "tsx": "latest",
    "typescript": "latest"
  }
}
